# Bek Docker Compose self-host template.
# Copy to .env.docker, replace secrets, then run:
# docker compose --env-file .env.docker --profile app up --build

# Host ports.
BEK_API_PORT=4317
BEK_WEB_PORT=5173
POSTGRES_PORT=54329
VALKEY_PORT=63799
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Browser/API URLs.
BEK_PUBLIC_URL=http://localhost:4317
BEK_WEB_API_URL=http://localhost:4317

# Admin API. Replace the server token for shared installs. The web console will
# prompt for it at runtime. Production web builds reject embedded admin tokens.
BEK_ADMIN_API_TOKEN=change-me-local-only
BEK_ALLOW_UNAUTHENTICATED_LOCAL=false
BEK_REQUIRE_ADMIN_AUTH=true
BEK_ADMIN_ORIGINS=http://localhost:5173
BEK_MAX_REQUEST_BODY_BYTES=262144
BEK_RATE_LIMIT_MAX_REQUESTS=600
BEK_RATE_LIMIT_WINDOW_MS=60000
BEK_TRUST_PROXY_HEADERS=false

# Postgres-backed Bek snapshot storage inside Compose.
BEK_STORAGE=postgres
BEK_DB_AUTO_SEED=true
BEK_DB_LOGGER=false
BEK_ORG_ID=org_demo
BEK_RUN_ADVANCEMENT=worker_local
BEK_WORKER_QUEUE_BACKEND=postgres
DATABASE_URL=postgres://bek:bek@postgres:5432/bek

# Local backing services.
POSTGRES_USER=bek
POSTGRES_PASSWORD=bek
POSTGRES_DB=bek
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_BUCKET=bek-artifacts
S3_ACCESS_KEY_ID=bek
S3_SECRET_ACCESS_KEY=bek-local-dev
MINIO_ROOT_USER=bek
MINIO_ROOT_PASSWORD=bek-local-dev

# Local credential vault. Generate with:
#   printf 'hex:%s\n' "$(openssl rand -hex 32)"
# Keep this stable for persisted installs; losing it means Slack OAuth bot
# tokens encrypted in the local vault cannot be decrypted.
BEK_CREDENTIAL_MASTER_KEY=
BEK_CREDENTIAL_KEY_ID=bek-local-vault-v1

# Slack app. Unsigned Slack events are only for local tests/demos.
# OAuth exchange stores the bot token in the local encrypted vault when
# BEK_CREDENTIAL_MASTER_KEY is set. SLACK_BOT_TOKEN remains a manual fallback.
BEK_DEV_UNSIGNED_SLACK=false
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_STATE_SECRET=
SLACK_REDIRECT_URI=http://localhost:4317/api/slack/oauth/callback
# This template keeps exchange off until you opt in. If unset, production mode
# exchanges codes by default.
BEK_SLACK_OAUTH_EXCHANGE=false
BEK_SLACK_BACKGROUND_DRAIN=true
SLACK_BOT_SCOPES=app_mentions:read,reactions:read,commands,chat:write
# Prefer team-scoped Slack identities: {"T123:U123":"principal_bryson"}.
# Legacy global keys such as {"U123":"principal_bryson"} only work when
# BEK_ALLOW_LEGACY_SLACK_USER_MAP=true.
BEK_ALLOW_LEGACY_SLACK_USER_MAP=false
BEK_SLACK_USER_PRINCIPAL_MAP={}

# Model providers and gateways.
BEK_MODEL_GATEWAY=local
BEK_MODEL_ROUTING_MODE=auto
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
BEK_AI_GATEWAY_TAGS=
BEK_AI_GATEWAY_MAX_RETRIES=0
BEK_AI_GATEWAY_TIMEOUT_MS=120000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LITELLM_BASE_URL=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# GitHub App settings for repo workflow.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=
# Deprecated alias still accepted by the API while older installs migrate.
GITHUB_WEBHOOK_SECRET=

# MCP/tool gateway.
MCP_CONFIG_PATH=
MCP_GATEWAY_ENCRYPTION_KEY=

# Runtime and sandbox providers. Compose leaves executable sandboxes disabled by
# default. Use docker-local only for trusted single-tenant installs where the
# worker process intentionally has Docker CLI/socket access.
BEK_RUNTIME_PROVIDER=ai_sdk
BEK_SANDBOX_PROVIDER=none
BEK_SANDBOX_EGRESS_ALLOWLIST=
E2B_API_KEY=
OPENCODE_BIN=opencode

# Observability.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bek
