# Bek local development
BEK_API_PORT=4317
BEK_WEB_PORT=5173
BEK_PUBLIC_URL=http://localhost:4317
# Vite dev fallback for host-machine frontend development.
VITE_BEK_API_URL=http://localhost:4317
# Runtime API URL emitted by the production/static web server.
BEK_WEB_API_URL=http://localhost:4317

# Admin API. The API fails closed unless a bearer token is configured or the
# explicit local-only bypass is enabled. Hosted/shared/prod must set
# BEK_ADMIN_API_TOKEN and BEK_REQUIRE_ADMIN_AUTH=true. The admin console can
# prompt for the token at runtime; VITE_BEK_ADMIN_API_TOKEN is a dev-server-only
# convenience and production web builds reject it.
BEK_ADMIN_API_TOKEN=
VITE_BEK_ADMIN_API_TOKEN=
BEK_ADMIN_PRINCIPAL_ID=principal_admin
BEK_ALLOW_UNAUTHENTICATED_LOCAL=true
BEK_REQUIRE_ADMIN_AUTH=false
BEK_ADMIN_ORIGINS=http://localhost:5173
BEK_MAX_REQUEST_BODY_BYTES=262144
BEK_RATE_LIMIT_MAX_REQUESTS=600
BEK_RATE_LIMIT_WINDOW_MS=60000
BEK_TRUST_PROXY_HEADERS=false

# Local persistence and queues. Keep BEK_STORAGE=memory for zero-config demos;
# set BEK_STORAGE=postgres to make apps/api use DATABASE_URL.
BEK_STORAGE=memory
BEK_DB_AUTO_SEED=true
BEK_DB_LOGGER=false
BEK_ORG_ID=org_demo
BEK_RUN_ADVANCEMENT=worker_local
# memory is zero-config; postgres persists worker queue records/dead letters/events
# when BEK_STORAGE=postgres and migrations have run.
BEK_WORKER_QUEUE_BACKEND=memory
DATABASE_URL=postgres://bek:bek@localhost:54329/bek
REDIS_URL=redis://localhost:63799
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=bek-artifacts
S3_ACCESS_KEY_ID=bek
S3_SECRET_ACCESS_KEY=bek-local-dev

# Local credential vault. Generate with:
#   printf 'hex:%s\n' "$(openssl rand -hex 32)"
# Keep this stable for persisted installs; losing it means Slack OAuth bot
# tokens encrypted in the local vault cannot be decrypted.
BEK_CREDENTIAL_MASTER_KEY=
BEK_CREDENTIAL_KEY_ID=bek-local-vault-v1

# Slack app. Unsigned Slack events are only for local tests/demos.
# OAuth exchange stores the bot token in the local encrypted vault when
# BEK_CREDENTIAL_MASTER_KEY is set. SLACK_BOT_TOKEN remains a manual fallback.
BEK_DEV_UNSIGNED_SLACK=false
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_STATE_SECRET=
SLACK_REDIRECT_URI=http://localhost:4317/api/slack/oauth/callback
# Set true to exchange OAuth codes locally; production exchanges by default.
BEK_SLACK_OAUTH_EXCHANGE=false
BEK_SLACK_BACKGROUND_DRAIN=true
SLACK_BOT_SCOPES=app_mentions:read,reactions:read,commands,chat:write,channels:read,groups:read
# Prefer team-scoped Slack identities: {"T123:U123":"principal_bryson"}.
# Legacy global keys such as {"U123":"principal_bryson"} only work when the
# local unauthenticated bypass is enabled or this explicit compatibility flag is
# set to true.
BEK_ALLOW_LEGACY_SLACK_USER_MAP=false
BEK_SLACK_USER_PRINCIPAL_MAP={}

# Model providers and gateways.
BEK_MODEL_GATEWAY=local
BEK_MODEL_ROUTING_MODE=auto
BEK_MODEL_PROVIDER_REGISTRY_JSON=
BEK_MODEL_PROVIDER_REGISTRY_PATH=
BEK_MODEL_BENCHMARKS_JSON=
BEK_MODEL_BENCHMARKS_PATH=
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
BEK_AI_GATEWAY_TAGS=
BEK_AI_GATEWAY_MAX_RETRIES=0
BEK_AI_GATEWAY_TIMEOUT_MS=120000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
LITELLM_BASE_URL=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# GitHub App settings for repo workflow.
BEK_GITHUB_EXECUTION=disabled
GITHUB_API_BASE_URL=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_INSTALLATION_ID=
# Deprecated alias still accepted by the API while older installs migrate.
GITHUB_WEBHOOK_SECRET=

# MCP/tool gateway.
MCP_CONFIG_PATH=
MCP_GATEWAY_ENCRYPTION_KEY=

# Runtime and sandbox providers. The local demo keeps executable sandboxes
# disabled by default. Use docker-local only for trusted single-tenant installs
# where the worker process intentionally has Docker CLI/socket access.
BEK_RUNTIME_PROVIDER=ai_sdk
BEK_SANDBOX_PROVIDER=none
BEK_SANDBOX_EGRESS_ALLOWLIST=
E2B_API_KEY=
OPENCODE_BIN=opencode

# Observability.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bek
