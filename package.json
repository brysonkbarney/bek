{
  "name": "bek",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Claude Tag-style Slack teammate: one visible handle, any model/tool/repo/sandbox behind it.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.1.3"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "dev:api": "pnpm --filter @bek/api dev",
    "dev:web": "pnpm --filter @bek/web dev",
    "worker:local": "pnpm --filter @bek/worker local",
    "db:generate": "pnpm --filter @bek/db db:generate",
    "db:migrate": "pnpm --filter @bek/db db:migrate",
    "db:seed": "pnpm --filter @bek/db seed",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "smoke": "bash scripts/smoke.sh",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm smoke"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
