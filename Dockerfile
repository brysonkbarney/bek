# syntax=docker/dockerfile:1.7

ARG NODE_VERSION=24-bookworm-slim
ARG PNPM_VERSION=11.1.3

FROM node:${NODE_VERSION} AS base
WORKDIR /app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

ARG PNPM_VERSION
RUN npm install --global pnpm@${PNPM_VERSION}

FROM base AS deps

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json tsconfig.base.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY packages/core/package.json packages/core/package.json
COPY packages/credentials/package.json packages/credentials/package.json
COPY packages/db/package.json packages/db/package.json
COPY packages/github/package.json packages/github/package.json
COPY packages/mcp-gateway/package.json packages/mcp-gateway/package.json
COPY packages/model-router/package.json packages/model-router/package.json
COPY packages/observability/package.json packages/observability/package.json
COPY packages/runtime/package.json packages/runtime/package.json
COPY packages/sandbox/package.json packages/sandbox/package.json
COPY packages/slack/package.json packages/slack/package.json
COPY packages/worker/package.json packages/worker/package.json

RUN pnpm install --frozen-lockfile

FROM deps AS source
COPY . .

FROM source AS api_worker_build
RUN pnpm --filter @bek/api... --filter @bek/worker... build
RUN pnpm --filter @bek/api deploy --legacy --prod /out/api \
  && pnpm --filter @bek/worker deploy --legacy --prod /out/worker

FROM source AS migrate
ENV NODE_ENV=production
USER node
CMD ["pnpm", "db:migrate"]

FROM node:${NODE_VERSION} AS runtime_base
WORKDIR /app
RUN node -e 'const fs=require("node:fs");const script="";fs.writeFileSync("/usr/local/bin/normalize-bek-runtime.cjs",Buffer.from(script,"base64"));fs.chmodSync("/usr/local/bin/normalize-bek-runtime.cjs",0o755);'

FROM runtime_base AS api
ENV NODE_ENV=production
ENV BEK_API_PORT=4317
COPY --from=api_worker_build --chown=node:node /out/api ./
RUN node /usr/local/bin/normalize-bek-runtime.cjs /app
EXPOSE 4317
USER node
CMD ["node", "dist/index.js"]

FROM runtime_base AS worker
ENV NODE_ENV=production
COPY --from=api_worker_build --chown=node:node /out/worker ./
RUN node /usr/local/bin/normalize-bek-runtime.cjs /app
USER node
CMD ["node", "dist/runner.js"]

FROM source AS web_build
RUN pnpm --filter @bek/web... build
RUN pnpm --filter @bek/web deploy --legacy --prod /out/web

FROM node:${NODE_VERSION} AS web
WORKDIR /app
ENV NODE_ENV=production
ENV BEK_WEB_PORT=5173
COPY --from=web_build --chown=node:node /out/web/dist ./dist
COPY --from=source --chown=node:node /app/apps/web/server.mjs ./server.mjs
EXPOSE 5173
USER node
CMD ["node", "server.mjs"]
